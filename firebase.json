{
  "functions": {
    "source": "functions"
  },

  "firestore": {
    "indexes": "firestore.indexes.json"
  },

  "hosting": {
    "public": "dist",

    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],

    "rewrites": [
       {
    "source": "/robots.txt",
    "function": "robots"
  },
      {
        "source": "/sitemap.xml",
        "function": "sitemap"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
